# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ── Database ─────────────────────────────────
# Local docker-compose value — change for production
DATABASE_URL=postgresql://geowatch:geowatch_dev_password@localhost:5432/geowatch?schema=public

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────
# Generate strong secrets in production: openssl rand -base64 48
JWT_SECRET=dev_only_change_me_jwt_secret_please
JWT_REFRESH_SECRET=dev_only_change_me_refresh_secret_please

# ── Seed ─────────────────────────────────────
# Only used by `npm run db:seed` for local dev. Never set in production envs.
ADMIN_SEED_PASSWORD=ChangeMe123!

# ── AI (used from Stage 5 onward) ─────────────
OPENAI_API_KEY=

# ── News ingestion (used from Stage 4 onward) ─
NEWSAPI_KEY=
