// GeoWatch — Prisma schema
// Postgres 16

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum CountryStatus {
  conflict
  crisis
  unstable
  stable
}

enum EventCategory {
  military
  economic
  political
  humanitarian
}

enum UserRole {
  superadmin
  editor
  viewer
}

enum SourceType {
  wire
  rss
  api
  scraper
}

// Editorial workflow stage of a story. `published` (boolean) stays the
// public-visibility source of truth; status drives the admin board. The two
// are kept in sync by ArticlesService (status=published ⇔ published=true).
enum ArticleStatus {
  idea
  draft
  in_review
  ready
  scheduled
  published
  archived
}

// Editorial framing shown as a badge on cards — distinct from `kind`
// (editorial vs wire, derived from authorId/sourceId): a wire story stays
// null (plain "News"), an editorial piece can additionally be tagged as
// one of these so a reader can tell analysis from breaking coverage from
// opinion at a glance, per the homepage-hierarchy review.
enum ArticleContentType {
  analysis
  opinion
  exclusive
  explainer
  fact_check
  live
}

enum TaskPriority {
  urgent
  high
  normal
}

// ─────────────────────────────────────────────
// Countries
// ─────────────────────────────────────────────

model Country {
  id             String        @id @db.Char(2) // ISO 3166-1 alpha-2
  iso3           String?       @db.Char(3) // ISO 3166-1 alpha-3 — needed to join IMF/DBnomics data, which keys on alpha-3
  name           String        @db.VarChar(100)
  flagEmoji      String?       @map("flag_emoji") @db.VarChar(8)
  region         String?       @db.VarChar(100)
  capital        String?       @db.VarChar(100)
  population     BigInt?
  gdpUsd         BigInt?       @map("gdp_usd")
  latitude       Decimal?      @db.Decimal(8, 5)
  longitude      Decimal?      @db.Decimal(8, 5)
  status         CountryStatus @default(stable)
  statusOverride Boolean       @default(false) @map("status_override")
  riskScore      Decimal       @default(0.0) @map("risk_score") @db.Decimal(4, 2)
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  events             Event[]
  articles           Article[]
  riskScores         RiskScoreHistory[]
  gdpHistory         GdpHistory[]
  populationHistory  PopulationHistory[]
  economicIndicators EconomicIndicator[]
  sanctionRecords    SanctionRecord[]
  healthScores       CountryHealthScore[]
  conflictMonths     ConflictMonth[]
  sources            Source[]
  tradeAsReporter    TradeFlow[]          @relation("tradeAsReporter")
  tradeAsPartner     TradeFlow[]          @relation("tradeAsPartner")

  @@map("countries")
  @@index([status])
}

// Annual GDP per country, parsed automatically from the World Bank API.
// gdpUsd — current US$ (NY.GDP.MKTP.CD), the headline display figure;
// gdpConstUsd — constant 2015 US$ (NY.GDP.MKTP.KD), FX-noise-free real
// GDP that the stability classification in GdpService is based on.
model GdpHistory {
  id          String   @id @default(uuid()) @db.Uuid
  countryId   String   @map("country_id") @db.Char(2)
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  year        Int
  gdpUsd      BigInt   @map("gdp_usd")
  gdpConstUsd BigInt?  @map("gdp_const_usd")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([countryId, year])
  @@map("gdp_history")
}

// Annual total population (World Bank SP.POP.TOTL), parsed automatically
// alongside GDP. Powers the "population change over 10 years" indicator.
model PopulationHistory {
  id         String   @id @default(uuid()) @db.Uuid
  countryId  String   @map("country_id") @db.Char(2)
  country    Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  year       Int
  population BigInt
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([countryId, year])
  @@map("population_history")
}

model RiskScoreHistory {
  id          String   @id @default(uuid()) @db.Uuid
  countryId   String   @map("country_id") @db.Char(2)
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  score       Decimal  @db.Decimal(4, 2)
  breakdown   Json?
  computedAt  DateTime @default(now()) @map("computed_at")

  @@map("risk_scores")
  @@index([countryId, computedAt(sort: Desc)])
}

// ─────────────────────────────────────────────
// Macro Intelligence — World Bank / IMF indicators, sanctions pressure,
// and the composite Country Health score derived from them. Deliberately
// separate from RiskScoreHistory above (GDP-trend-based, drives the map's
// stability color) — this is a different, macro-indicator-percentile-based
// index, not a replacement.
// ─────────────────────────────────────────────

// Generic long-format store for World Bank / IMF WEO indicators — one row
// per (country, indicator, year). A single flexible table instead of one
// column/table per indicator, since new indicators get added over time.
model EconomicIndicator {
  id            String   @id @default(uuid()) @db.Uuid
  countryId     String   @map("country_id") @db.Char(2)
  country       Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  indicatorCode String   @map("indicator_code") @db.VarChar(64) // e.g. "WB:NY.GNP.PCAP.PP.CD", "IMF:NGDP_RPCH"
  source        String   @db.VarChar(32) // 'worldbank' | 'imf_weo'
  period        DateTime @db.Date // year stored as Jan 1 of that year
  value         Decimal  @db.Decimal(18, 4)
  isForecast    Boolean  @default(false) @map("is_forecast") // IMF WEO includes forecasts up to +5 years
  loadedAt      DateTime @default(now()) @updatedAt @map("loaded_at")

  @@unique([countryId, indicatorCode, period])
  @@map("economic_indicators")
  @@index([indicatorCode, period])
}

// Country-level aggregate sanctioned-entity counts (not individual entities
// — see OpenSanctionsAdapter for the licensing note on why this stays
// aggregate-only for now).
model SanctionRecord {
  id          String   @id @default(uuid()) @db.Uuid
  countryId   String   @map("country_id") @db.Char(2)
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  program     String   @db.VarChar(64) // e.g. "opensanctions:all"
  entityCount Int      @map("entity_count")
  asOf        DateTime @db.Date
  loadedAt    DateTime @default(now()) @updatedAt @map("loaded_at")

  @@unique([countryId, program, asOf])
  @@map("sanction_records")
}

// Bilateral trade totals (UN Comtrade, annual, current US$). Only each
// reporter's TOP partners per flow are stored (the analysis layer needs
// "who matters to whom", not the full 200×200 matrix).
model TradeFlow {
  id         String   @id @default(uuid()) @db.Uuid
  reporterId String   @map("reporter_id") @db.Char(2)
  reporter   Country  @relation("tradeAsReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  partnerId  String   @map("partner_id") @db.Char(2)
  partner    Country  @relation("tradeAsPartner", fields: [partnerId], references: [id], onDelete: Cascade)
  flow       String   @db.Char(1) // 'X' exports | 'M' imports, Comtrade flow codes
  year       Int
  valueUsd   BigInt   @map("value_usd")
  fetchedAt  DateTime @default(now()) @updatedAt @map("fetched_at")

  @@unique([reporterId, partnerId, flow, year])
  @@index([reporterId, year])
  @@map("trade_flows")
}

// Global energy benchmark prices (EIA Open Data). Deliberately not
// per-country — Brent/WTI/Henry Hub are world reference prices the
// analysis layer cites as market context for events.
model EnergyPrice {
  id       String   @id @default(uuid()) @db.Uuid
  series   String   @db.VarChar(16) // EIA series id: RBRTE, RWTC, RNGWHHD
  period   DateTime @db.Date
  value    Decimal  @db.Decimal(10, 2)
  units    String   @db.VarChar(16)
  loadedAt DateTime @default(now()) @updatedAt @map("loaded_at")

  @@unique([series, period])
  @@index([series, period])
  @@map("energy_prices")
}

// Composite "Country Health" index — percentile-normalized weighted sum of
// EconomicIndicator + SanctionRecord values. Versioned (methodology) so a
// future v2 can run alongside v1 for comparison rather than overwriting it.
model CountryHealthScore {
  id          String   @id @default(uuid()) @db.Uuid
  countryId   String   @map("country_id") @db.Char(2)
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  scoreName   String   @map("score_name") @db.VarChar(64) // 'country_health'
  methodology String   @db.VarChar(16) // 'v1'
  period      DateTime @db.Date
  value       Decimal  @db.Decimal(6, 2)
  components  Json?
  computedAt  DateTime @default(now()) @map("computed_at")

  @@unique([countryId, scoreName, methodology, period])
  @@map("country_health_scores")
  @@index([scoreName, period])
}

// ─────────────────────────────────────────────
// Events
// ─────────────────────────────────────────────

model Event {
  id          String         @id @default(uuid()) @db.Uuid
  countryId   String?        @map("country_id") @db.Char(2)
  country     Country?       @relation(fields: [countryId], references: [id])
  title       String         @db.VarChar(255)
  description String?
  category    EventCategory
  severity    Int            @default(5) @db.SmallInt
  startedAt   DateTime?      @map("started_at")
  endedAt     DateTime?      @map("ended_at")
  sourceUrl   String?        @map("source_url")
  tags        String[]       @default([])
  createdBy   String?        @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at")

  articleLinks ArticleEvent[]

  @@map("events")
  @@index([countryId])
  @@index([category])
  @@index([startedAt(sort: Desc)])
}

// ─────────────────────────────────────────────
// Sources & Articles
// ─────────────────────────────────────────────

model Source {
  id                   String     @id @default(uuid()) @db.Uuid
  name                 String     @db.VarChar(100)
  type                 SourceType?
  url                  String
  apiKey               String?    @map("api_key")
  active               Boolean    @default(true)
  // Official government/institution outlet (press service, ministry, head of
  // state) as opposed to independent media — lets the analysis layer cite
  // "official statements" as a distinct evidence class.
  official             Boolean    @default(false)
  // For official sources: the state this outlet speaks for. Used as a
  // country-classification fallback — a head-of-state feed rarely names its
  // own country in headlines.
  countryId            String?    @map("country_id") @db.Char(2)
  country              Country?   @relation(fields: [countryId], references: [id])
  fetchIntervalMinutes Int        @default(15) @map("fetch_interval_minutes")
  lastFetched          DateTime?  @map("last_fetched")
  articleCount         Int        @default(0) @map("article_count")
  createdAt            DateTime   @default(now()) @map("created_at")

  // ── Source Registry fields (Entity Resolution / Data Fusion) ──
  // Free-text, not an enum: this column exists purely as human-readable
  // registry metadata ("company", "sanction", "vessel"...) — matching is
  // never done by joining on it, only EntityIdentifier equality resolves
  // entities. Null for ordinary article/RSS sources.
  entityType           String?    @map("entity_type")
  // Editorial confidence in this source's data quality, 1-10 — surfaced in
  // the admin Source Registry view, not currently used in resolution logic.
  trustScore           Int?       @map("trust_score")

  articles          Article[]
  entityIdentifiers EntityIdentifier[]
  entityAliases     EntityAlias[]
  entitySourceLinks EntitySourceLink[]
  entitySanctions   EntitySanction[]
  entityRelationships EntityRelationship[]
  entityOfficers    EntityOfficer[]
  entityEnrichmentAttempts EntityEnrichmentAttempt[]

  @@map("sources")
}

// ─────────────────────────────────────────────
// Entity Resolution / Data Fusion (Phase 1: exact-identifier matching only —
// no fuzzy scoring, no LLM merge. Each source is ingested independently and
// normalized into an EntityIdentifier/EntityAlias pair; resolution merges
// two records ONLY when they share an identifier of the same type+value
// (+countryId for nationally-scoped identifiers like a registration number,
// since e.g. "1025501701686" is only unique within Russia). Everything else
// stays as separate Entity rows rather than risk a false merge — the whole
// point of starting with identifiers-only is that a wrong merge silently
// corrupts which facts belong to which real-world company.
// ─────────────────────────────────────────────

enum EntityType {
  company
}

// Deliberately not scoped to a fixed catalog beyond what Phase 1 sources
// actually produce — OFAC's own "Registration Number"/"Tax ID No." labels
// vary by country and get folded into reg_number/tax_id here, with the
// country recorded on EntityIdentifier.countryId to keep them from
// colliding across jurisdictions.
enum IdentifierType {
  lei
  reg_number
  tax_id
  cik // SEC EDGAR Central Index Key — globally unique, US public companies
}

model Entity {
  id            String     @id @default(uuid()) @db.Uuid
  entityType    EntityType @default(company)
  canonicalName String
  // Best-known country, populated from an identifier's countryId or a
  // source's address hint during resolution. Not authoritative (a company
  // can legitimately operate across borders) — used only to bound the
  // fuzzy-match candidate pool to a sane size (comparing a new record
  // against every entity on file wouldn't scale past a few thousand rows).
  primaryCountryId String?  @map("primary_country_id") @db.Char(2)
  // ── Company profile fields (Track A schema expansion) ──
  // All sparse-by-source: not every source's raw payload has these, so most
  // stay null for entities from identifier-only sources (OFAC/EU/OFSI/Canada
  // /Australia). Populated by backfill (A2) and future adapter runs (A3).
  website           String? @db.VarChar(255)
  // Normalized, not a free-text passthrough — source-specific status strings
  // (e.g. Companies House "active"/"dissolved", France's "actif"/"cesse")
  // are mapped onto this fixed set by each adapter.
  status            String? @db.VarChar(20) // active | dissolved | liquidated | unknown
  industryCode      String? @map("industry_code") @db.VarChar(32) // source-native code (SIC, NAF...), not cross-source-normalized
  industryLabel     String? @map("industry_label")
  addressLine       String? @map("address_line")
  addressCity       String? @map("address_city") @db.VarChar(100)
  addressPostalCode String? @map("address_postal_code") @db.VarChar(20)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  identifiers  EntityIdentifier[]
  aliases      EntityAlias[]
  sourceLinks  EntitySourceLink[]
  sanctions    EntitySanction[]
  officers     EntityOfficer[]
  reviewsAsA   EntityMergeReview[] @relation("MergeReviewA")
  reviewsAsB   EntityMergeReview[] @relation("MergeReviewB")
  relationshipsAsParent EntityRelationship[] @relation("RelationshipParent")
  relationshipsAsChild  EntityRelationship[] @relation("RelationshipChild")
  articleMentions ArticleEntity[]
  enrichmentAttempts EntityEnrichmentAttempt[]

  @@index([primaryCountryId])
  @@map("entities")
}

enum OfficerRole {
  director
  beneficial_owner
  officer
}

// A per-source fact record of "who this source says is associated with this
// entity" — deliberately NOT a full Entity/Person with cross-source identity
// resolution (that's a much bigger schema decision, left open). Two sources
// reporting the same real person produce two separate rows here; nothing
// folds them together. This exists purely to surface "directors (where
// available)" in a company profile without reopening that decision.
model EntityOfficer {
  id        String      @id @default(uuid()) @db.Uuid
  entityId  String      @map("entity_id") @db.Uuid
  entity    Entity      @relation(fields: [entityId], references: [id], onDelete: Cascade)
  name      String
  role      OfficerRole
  countryId String?     @map("country_id") @db.Char(2)
  sourceId  String      @map("source_id") @db.Uuid
  source    Source      @relation(fields: [sourceId], references: [id])
  createdAt DateTime    @default(now()) @map("created_at")

  // Prevents duplicate rows on re-ingest of the same source (no per-officer
  // external id exists in most sources, so identity = this tuple).
  @@unique([entityId, name, role, sourceId])
  @@index([entityId])
  @@map("entity_officers")
}

enum MergeReviewStatus {
  pending
  approved
  rejected
}

// Phase 2: a fuzzy name+country match that could NOT be confirmed by a
// shared identifier gets queued here rather than auto-merged — the whole
// point of starting conservative is that a silent wrong merge is much
// harder to notice and undo than a human spending 10 seconds confirming
// "yes, these are the same company." entityA is the pre-existing entity;
// entityB is the new entity the just-ingested record created (ingestion
// never blocks on review — it always gets its own Entity row, and approving
// a review is what folds entityB's data into entityA and removes entityB).
model EntityMergeReview {
  id         String            @id @default(uuid()) @db.Uuid
  // Nullable + SET NULL (not the original CASCADE): a merge decision is an
  // audit record. With CASCADE, approving a review deletes entityB in the
  // same transaction, which immediately cascade-deletes the very row that
  // just recorded the decision — every "approved" row vanished the instant
  // it was created. Worse, entityA carrying CASCADE meant a later merge
  // that folds A into some other entity erases A's own merge history too.
  // The canonical-name snapshots below keep the record human-readable even
  // after the entities themselves are gone.
  entityAId  String?           @map("entity_a_id") @db.Uuid
  entityA    Entity?           @relation("MergeReviewA", fields: [entityAId], references: [id], onDelete: SetNull)
  entityBId  String?           @map("entity_b_id") @db.Uuid
  entityB    Entity?           @relation("MergeReviewB", fields: [entityBId], references: [id], onDelete: SetNull)
  // Snapshot at review-creation time — survives entity deletion, unlike the
  // live relations above.
  entityACanonicalName String? @map("entity_a_canonical_name")
  entityBCanonicalName String? @map("entity_b_canonical_name")
  confidence Float
  // Which signals contributed and their individual scores — e.g.
  // {"nameSimilarity": 0.94, "countryMatch": true}. Kept as a transparent
  // breakdown for the reviewer, not a black-box single number.
  matchedOn  Json              @map("matched_on")
  status     MergeReviewStatus @default(pending)
  reviewerId String?           @map("reviewer_id") @db.Uuid
  reviewer   User?             @relation(fields: [reviewerId], references: [id])
  createdAt  DateTime          @default(now()) @map("created_at")
  reviewedAt DateTime?         @map("reviewed_at")

  @@unique([entityAId, entityBId])
  @@index([status])
  @@map("entity_merge_reviews")
}

model EntityIdentifier {
  id        String         @id @default(uuid()) @db.Uuid
  entityId  String         @map("entity_id") @db.Uuid
  entity    Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)
  type      IdentifierType
  value     String
  // Empty string for globally-unique identifiers (LEI); an ISO2 code for
  // nationally-scoped ones (a registration/tax number is only unique within
  // its own country). Not nullable on purpose — Prisma's generated
  // findUnique input for a compound @@unique requires every field to be
  // non-null, so a real null here would make this identifier unlookupable.
  countryId String         @default("") @map("country_id") @db.VarChar(2)
  sourceId  String?        @map("source_id") @db.Uuid
  source    Source?        @relation(fields: [sourceId], references: [id])
  createdAt DateTime       @default(now()) @map("created_at")

  @@unique([type, value, countryId])
  @@index([entityId])
  @@map("entity_identifiers")
}

model EntityAlias {
  id        String   @id @default(uuid()) @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  name      String
  sourceId  String?  @map("source_id") @db.Uuid
  source    Source?  @relation(fields: [sourceId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([entityId, name])
  @@index([entityId])
  @@map("entity_aliases")
}

// Raw per-source record backing an Entity — kept for audit ("why did we
// decide this") and so a source can be safely re-ingested (upsert by
// sourceId+externalId) without duplicating aliases/identifiers.
model EntitySourceLink {
  id         String   @id @default(uuid()) @db.Uuid
  entityId   String   @map("entity_id") @db.Uuid
  entity     Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  sourceId   String   @map("source_id") @db.Uuid
  source     Source   @relation(fields: [sourceId], references: [id])
  externalId String   @map("external_id")
  rawPayload Json     @map("raw_payload")
  fetchedAt  DateTime @default(now()) @map("fetched_at")

  @@unique([sourceId, externalId])
  @@index([entityId])
  @@map("entity_source_links")
}

// One row per (entity, on-demand-registry) enrichment attempt, whether or
// not it found anything — distinct from EntitySourceLink, which only
// records a SUCCESSFUL match. Without a negative-result record, a nightly
// sweep over the sanctioned-entity pool (see EntityIngestionService's
// registry-sweep crons) couldn't tell "never tried against this registry"
// from "tried and this entity genuinely isn't in it," and would either
// re-attempt the same failed lookups forever or never converge on full
// coverage of the pool.
model EntityEnrichmentAttempt {
  entityId    String   @map("entity_id") @db.Uuid
  entity      Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  sourceId    String   @map("source_id") @db.Uuid
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  attemptedAt DateTime @default(now()) @map("attempted_at")
  found       Boolean

  @@id([entityId, sourceId])
  @@map("entity_enrichment_attempts")
}

// Per-entity sanction listing — distinct from the pre-existing SanctionRecord
// above (that one is a per-country OpenSanctions entity-count aggregate for
// the Country Health score; this one is "this specific resolved Entity is
// listed under this specific regime/program").
model EntitySanction {
  id        String   @id @default(uuid()) @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  regime    String
  program   String
  sourceId  String   @map("source_id") @db.Uuid
  source    Source   @relation(fields: [sourceId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([entityId, regime, program])
  @@index([entityId])
  @@map("entity_sanctions")
}

// Corporate ownership structure — currently sourced from GLEIF's free
// Level 2 relationship records (direct-parent / direct-children), the only
// source in this project with genuinely structured ownership data rather
// than free-text mentions. parentId owns/consolidates childId.
model EntityRelationship {
  id        String   @id @default(uuid()) @db.Uuid
  parentId  String   @map("parent_id") @db.Uuid
  parent    Entity   @relation("RelationshipParent", fields: [parentId], references: [id], onDelete: Cascade)
  childId   String   @map("child_id") @db.Uuid
  child     Entity   @relation("RelationshipChild", fields: [childId], references: [id], onDelete: Cascade)
  sourceId  String   @map("source_id") @db.Uuid
  source    Source   @relation(fields: [sourceId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@map("entity_relationships")
}

model Article {
  id                     String    @id @default(uuid()) @db.Uuid
  sourceId               String?   @map("source_id") @db.Uuid
  source                 Source?   @relation(fields: [sourceId], references: [id])
  countryId              String?   @map("country_id") @db.Char(2)
  country                Country?  @relation(fields: [countryId], references: [id])
  externalId             String?   @map("external_id")
  url                    String    @unique
  title                  String
  body                   String?
  publishedAt            DateTime? @map("published_at")
  language               String    @default("en") @db.Char(2)
  category               EventCategory?
  contentType            ArticleContentType? @map("content_type")
  tags                   String[]  @default([])
  aiSummary              String?   @map("ai_summary")
  aiSummaryApproved      Boolean   @default(false) @map("ai_summary_approved")
  aiSummaryApprovedBy    String?   @map("ai_summary_approved_by") @db.Uuid
  aiSummaryApprovedAt    DateTime? @map("ai_summary_approved_at")
  sentimentScore         Decimal?  @map("sentiment_score") @db.Decimal(4, 3)
  contentHash            String?   @unique @map("content_hash")
  imageUrl               String?   @map("image_url")
  published              Boolean   @default(false)
  status                 ArticleStatus @default(draft)
  // When status=scheduled: the moment the auto-publisher cron flips it live.
  scheduledAt            DateTime? @map("scheduled_at")
  authorId               String?   @map("author_id") @db.Uuid
  author                 User?     @relation(fields: [authorId], references: [id])
  fetchedAt              DateTime  @default(now()) @map("fetched_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  // Null until the sanctioned-entity mention scan has run once — distinct
  // from "entityMentions is empty," which is also true for an article that
  // genuinely mentions no sanctioned entity. Without this, a backfill job
  // filtering on "has no mentions yet" would re-scan every zero-match
  // article forever instead of converging.
  entityMentionsScannedAt DateTime? @map("entity_mentions_scanned_at")

  eventLinks    ArticleEvent[]
  entityMentions ArticleEntity[]
  comments      Comment[]
  revisions     ArticleRevision[]

  @@map("articles")
  @@index([status])
  @@index([countryId])
  @@index([category])
  @@index([publishedAt(sort: Desc)])
  @@index([sourceId])
}

model ArticleEvent {
  articleId  String  @map("article_id") @db.Uuid
  article    Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  eventId    String  @map("event_id") @db.Uuid
  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  confidence Decimal? @db.Decimal(4, 3)

  @@id([articleId, eventId])
  @@map("article_events")
}

// Auto-resolved keyword mentions of a SANCTIONED Entity within an article's
// title/body — deliberately scoped to sanctioned entities only (not every
// resolved company), matching the actual product need ("a sanctioned
// company mentioned in an article should resolve") rather than attempting
// general company-mention extraction against the full ~20k-entity pool,
// which wouldn't scale as a per-article keyword scan. matchedText records
// which alias/name actually matched, for a human to sanity-check false
// positives (a short/generic company name colliding with ordinary text).
model ArticleEntity {
  articleId   String   @map("article_id") @db.Uuid
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  entityId    String   @map("entity_id") @db.Uuid
  entity      Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  matchedText String   @map("matched_text")
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([articleId, entityId])
  @@index([entityId])
  @@map("article_entities")
}

// ─────────────────────────────────────────────
// Users / Auth
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  role         UserRole  @default(viewer)
  displayName  String?   @map("display_name") @db.VarChar(50)
  avatarUrl    String?   @map("avatar_url")
  active       Boolean   @default(true)
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")

  refreshTokens RefreshToken[]
  articles      Article[]
  comments      Comment[]
  tasks         EditorialTask[]
  sentMessages     Message[] @relation("sentMessages")
  receivedMessages Message[] @relation("receivedMessages")
  entityMergeReviews EntityMergeReview[]

  @@map("users")
}

// Personal editorial to-do items ("My tasks" on the admin dashboard).
// Per-user, not shared: the design is a journalist's own checklist.
model EditorialTask {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String       @db.VarChar(300)
  done      Boolean      @default(false)
  deadline  DateTime?
  priority  TaskPriority @default(normal)
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("editorial_tasks")
  @@index([userId, done])
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  articleId String   @map("article_id") @db.Uuid
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("comments")
  @@index([articleId, createdAt(sort: Desc)])
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
  @@index([userId])
}

// ─────────────────────────────────────────────
// Analytics
// ─────────────────────────────────────────────

model PageView {
  id         BigInt   @id @default(autoincrement())
  entityType String   @map("entity_type") @db.VarChar(20)
  entityId   String   @map("entity_id")
  sessionId  String?  @map("session_id")
  // Referring host ("news.google.com", "t.co", …), null = direct/unknown.
  // Only the host is stored — full referrer URLs can carry query-string PII.
  referrer   String?  @db.VarChar(120)
  viewedAt   DateTime @default(now()) @map("viewed_at")

  @@map("page_views")
  @@index([entityType, entityId])
  @@index([viewedAt(sort: Desc)])
}

// Monthly per-country conflict intensity aggregated from UCDP GED events
// (final annual dataset + monthly candidate releases). We store aggregates,
// not raw events — the platform needs trend and magnitude, not incident
// coordinates, and GED raw would be ~300k rows.
model ConflictMonth {
  id         String   @id @default(uuid()) @db.Uuid
  countryId  String   @map("country_id") @db.Char(2)
  country    Country  @relation(fields: [countryId], references: [id])
  // First day of the month, UTC.
  month      DateTime
  events     Int
  deaths     Int // UCDP "best" fatality estimates summed
  stateBased Int      @map("state_based")
  nonState   Int      @map("non_state")
  oneSided   Int      @map("one_sided")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([countryId, month])
  @@map("conflict_months")
  @@index([month(sort: Desc)])
}

// Content snapshot for the editor's History panel. Written by the autosave
// path at most once per collapse window (5 min) plus on every status
// change, so a long writing session leaves a readable trail, not noise.
model ArticleRevision {
  id        String   @id @default(uuid()) @db.Uuid
  articleId String   @map("article_id") @db.Uuid
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title     String
  aiSummary String?  @map("ai_summary")
  body      String?
  status    ArticleStatus
  authorId  String?  @map("author_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@map("article_revisions")
  @@index([articleId, createdAt(sort: Desc)])
}

// Internal editor-to-editor direct messages ("Messages" in the sidebar).
model Message {
  id        String    @id @default(uuid()) @db.Uuid
  fromId    String    @map("from_id") @db.Uuid
  from      User      @relation("sentMessages", fields: [fromId], references: [id], onDelete: Cascade)
  toId      String    @map("to_id") @db.Uuid
  to        User      @relation("receivedMessages", fields: [toId], references: [id], onDelete: Cascade)
  body      String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("messages")
  @@index([toId, readAt])
  @@index([fromId, toId, createdAt(sort: Desc)])
}
